# ═══════════════════════════════════════════════════════════════════════════
#  .env.example — шаблон переменных окружения для GDPX | WORK BOT
#  Скопируй в .env и заполни своими значениями.
#  НЕ КОММИТЬ .env с реальными секретами!
# ═══════════════════════════════════════════════════════════════════════════

# ── Telegram Bot ─────────────────────────────────────────────────────────
# Токен из @BotFather
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Формат разметки сообщений (HTML | MarkdownV2). Рекомендуется HTML.
BOT_PARSE_MODE=HTML

# ── PostgreSQL ───────────────────────────────────────────────────────────
# При запуске через Docker Compose POSTGRES_HOST = имя сервиса (postgres).
# При локальном запуске — localhost.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gdpx_bot
POSTGRES_USER=gdpx_bot
POSTGRES_PASSWORD=change_me_strong_password

# ── Redis ────────────────────────────────────────────────────────────────
# Хранилище FSM состояний.
# Пусто или не задан → MemoryStorage (данные теряются при перезапуске).
# Docker: redis://redis:6379/0
# Локально: redis://localhost:6379/0
REDIS_URL=

# ── HTTP (FastAPI / health-check) ────────────────────────────────────────
# uvicorn запускается в том же процессе, что и бот.
# GET /health — liveness, GET /health/ready — readiness.
HTTP_HOST=0.0.0.0
HTTP_PORT=8000

# ── Moderation ───────────────────────────────────────────────────────────
# Telegram chat_id супергруппы, куда форвардятся заявки на модерацию.
# Можно использовать MODERATION_CHAT_ID или устаревший алиас ARCHIVE_CHAT_ID.
MODERATION_CHAT_ID=-100000000000

# ── Crypto Pay (опционально) ─────────────────────────────────────────────
# API-токен из @CryptoBot → My Apps. Пусто — выплаты через CryptoPay отключены.
# CRYPTO_PAY_TOKEN=
# Актив для выплат (USDT, TON, BTC …)
# CRYPTO_ASSET=USDT

# ── Служебные алерты (опционально) ───────────────────────────────────────
# chat_id для системных уведомлений (ошибки CryptoPay, etc.). Пусто — не слать.
# ALERT_TELEGRAM_CHAT_ID=
# Минимальный интервал между одинаковыми алертами, сек (по умолчанию 900).
# ALERT_CRYPTOBOT_COOLDOWN_SEC=900
# Включать ли CryptoPay в GET /health/ready. Требует CRYPTO_PAY_TOKEN.
# HEALTH_READY_INCLUDE_CRYPTOBOT=true

# ── Брендовые ссылки в меню селлера (опционально) ────────────────────────
# Пусто или не задана — соответствующая кнопка не отображается.
BRAND_CHANNEL_URL=
BRAND_CHAT_URL=
BRAND_PAYMENTS_URL=
